# Block internal tooling from being served on the public site.
# The /tools/ directory holds maintenance scripts (e.g. the daily social
# publisher) that are checked into the repo for durable state but must not
# be publicly accessible.
/tools/* /404.html 404

# Old standalone "How to Apply for Colombian Citizenship" guide was merged into
# the Colombian Citizenship Exam study guide on 2026-04-24. Anyone arriving from
# Google or an old internal link gets a 301 to the consolidated page.
/how-to-apply-for-colombian-citizenship-through-naturalization/  /colombian-citizenship-exam-study-guide/  301

# Legacy WordPress-style paginated archive URLs. The static port renders the
# entire archive on the section index page (with native lazy-loaded images),
# so /page/N/ links from old indexes or external sites get a 301 to the
# canonical archive instead of falling through to the homepage.
/section/guides/page/*    /section/guides/    301
/section/explore/page/*   /section/explore/   301
/section/live/page/*      /section/live/      301
/section/eat-drink/page/* /section/eat-drink/ 301
/section/stay/page/*      /section/stay/      301
/section/magazine/page/*  /section/magazine/  301
/category/now/page/*      /category/now/      301
